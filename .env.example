# --- Clerk (client + server auth) -------------------------------------------
# Dashboard → API keys: https://dashboard.clerk.com/last-active?path=api-keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Convex ------------------------------------------------------------------
# Set automatically by `npx convex dev`.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# NOTE: CLERK_JWT_ISSUER_DOMAIN is NOT set here. It belongs on the Convex
# deployment (read by convex/auth.config.ts):
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://<your>.clerk.accounts.dev
